# Example environment variables for local development
# Copy this file to .env and adjust values for your machine.

MYSQL_HOST_PORT=YOUR_PORT_HERE
MYSQL_ROOT_PASSWORD=YOUR_PASSWORD_HERE
MYSQL_DATABASE=YOUR_DATABASE_NAME_HERE

KAFKA_HOST_PORT=YOUR_KAFKA_PORT_HERE

ConnectionStrings__DefaultConnection=Server=YOUR_HOST_HERE;Port=YOUR_PORT_HERE;Database=YOUR_DATABASE_NAME_HERE;Uid=YOUR_USERNAME_HERE;Pwd=YOUR_PASSWORD_HERE;
